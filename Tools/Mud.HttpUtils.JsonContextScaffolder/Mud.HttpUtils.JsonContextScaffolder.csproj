<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>Exe</OutputType>
		<TargetFramework>net8.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<LangVersion>latest</LangVersion>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>
		<Description>Mud HttpUtils JSON Context Scaffolder — 扫描 [HttpJsonSerializable] 标注类型，产出 JsonSerializerContext 源文件（支持 Native AOT）。</Description>
		<PackageTags>Mud;HttpUtils;AOT;Json;Scaffolder;JsonSerializerContext;NativeAOT</PackageTags>
		<Product>Mud Http Utils JSON Context Scaffolder</Product>
		<PackageId>Mud.HttpUtils.JsonContextScaffolder</PackageId>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<AssemblyName>Mud.HttpUtils.JsonContextScaffolder</AssemblyName>
		<IsPackable>true</IsPackable>
		<PackAsTool>true</PackAsTool>
		<ToolCommandName>mud-jsonctx</ToolCommandName>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.Build.Locator" Version="1.7.8" />
		<PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" Version="4.11.0" />
		<PackageReference Include="Microsoft.CodeAnalysis.Workspaces.MSBuild" Version="4.11.0" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\..\Mud.HttpUtils.Attributes\Mud.HttpUtils.Attributes.csproj" />
	</ItemGroup>

	<ItemGroup>
		<None Include="README.md" Pack="true" PackagePath="\" />
		<None Include="..\..\Icon.png" Pack="true" PackagePath="\" />
	</ItemGroup>

</Project>
